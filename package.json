{
  "name": "django-shell",
  "displayName": "Django Shell",
  "description": "A custom UI Django shell console for VS Code. The notebook frontend is deprecated.",
  "version": "0.0.907018",
  "publisher": "newdlops",
  "license": "UNLICENSED",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/django-shell.git"
  },
  "bugs": {
    "url": "https://github.com/newdlops/django-shell/issues"
  },
  "homepage": "https://github.com/newdlops/django-shell#readme",
  "categories": [
    "Other",
    "Notebooks"
  ],
  "keywords": [
    "django",
    "python",
    "shell",
    "repl",
    "console",
    "notebook"
  ],
  "galleryBanner": {
    "color": "#0d4f3a",
    "theme": "dark"
  },
  "qna": false,
  "main": "./out/extension.js",
  "extensionDependencies": [
    "ms-python.python",
    "ms-python.vscode-pylance"
  ],
  "extensionOptionalDependencies": [
    "newdlops.django-orm-intellisense",
    "newdlops.intellisense-recursion",
    "newdlops.vscode-auto-import"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "activationEvents": [
    "onCommand:djangoShell.acceptInput",
    "onCommand:djangoShell.debugShell",
    "onCommand:djangoShell.debug.continue",
    "onCommand:djangoShell.debug.pause",
    "onCommand:djangoShell.debug.stepOver",
    "onCommand:djangoShell.debug.stepInto",
    "onCommand:djangoShell.debug.stepOut",
    "onCommand:djangoShell.debug.restart",
    "onCommand:djangoShell.debug.stop",
    "onCommand:djangoShell.newOverlayTab",
    "onCommand:djangoShell.openConsole",
    "onCommand:djangoShell.openModelData",
    "onCommand:djangoShell.openNotebookConsoleDeprecated",
    "onCommand:djangoShell.overlayAcceptInput",
    "onCommand:djangoShell.overlayInsertNewline",
    "onCommand:djangoShell.overlaySkipCurrentInput",
    "onCommand:djangoShell.refreshInspector",
    "onCommand:djangoShell.refreshModelCatalog",
    "onCommand:djangoShell.runModelQuery",
    "onCommand:djangoShell.showOverlayEditor",
    "onCommand:djangoShell.showEnvironment",
    "onCommand:djangoShell.showDiagnostics",
    "onView:djangoShell.debugAnalysis",
    "onNotebook:django-shell-console",
    "onView:djangoShell.modelCatalog",
    "onView:djangoShell.runtimeInspector",
    "onRenderer:django-shell-terminal-renderer"
  ],
  "contributes": {
    "commands": [
      {
        "command": "djangoShell.openConsole",
        "title": "Django Shell: Open Console",
        "category": "Django Shell",
        "icon": "$(terminal)"
      },
      {
        "command": "djangoShell.debugShell",
        "title": "Django Shell: Debug Current Shell",
        "category": "Django Shell",
        "icon": "$(debug-start)"
      },
      {
        "command": "djangoShell.debug.continue",
        "title": "Django Shell: Continue Debugging",
        "category": "Django Shell",
        "icon": "$(debug-continue)"
      },
      {
        "command": "djangoShell.debug.pause",
        "title": "Django Shell: Pause Debugging",
        "category": "Django Shell",
        "icon": "$(debug-pause)"
      },
      {
        "command": "djangoShell.debug.stepOver",
        "title": "Django Shell: Step Over",
        "category": "Django Shell",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "djangoShell.debug.stepInto",
        "title": "Django Shell: Step Into",
        "category": "Django Shell",
        "icon": "$(debug-step-into)"
      },
      {
        "command": "djangoShell.debug.stepOut",
        "title": "Django Shell: Step Out",
        "category": "Django Shell",
        "icon": "$(debug-step-out)"
      },
      {
        "command": "djangoShell.debug.restart",
        "title": "Django Shell: Restart Debugging",
        "category": "Django Shell",
        "icon": "$(debug-restart)"
      },
      {
        "command": "djangoShell.debug.stop",
        "title": "Django Shell: Stop Debugging",
        "category": "Django Shell",
        "icon": "$(debug-stop)"
      },
      {
        "command": "djangoShell.newOverlayTab",
        "title": "Django Shell: New Overlay Tab",
        "category": "Django Shell",
        "icon": "$(add)"
      },
      {
        "command": "djangoShell.openNotebookConsoleDeprecated",
        "title": "Django Shell: Open Notebook Console (Deprecated)",
        "category": "Django Shell",
        "icon": "$(notebook)"
      },
      {
        "command": "djangoShell.showOverlayEditor",
        "title": "Django Shell: Show Overlay Editor",
        "category": "Django Shell",
        "icon": "$(edit)"
      },
      {
        "command": "djangoShell.overlayRunCurrentInput",
        "title": "Django Shell: Run Current Python Input",
        "category": "Django Shell",
        "icon": "$(run)"
      },
      {
        "command": "djangoShell.overlaySkipCurrentInput",
        "title": "Django Shell: Skip Current Python Input",
        "category": "Django Shell",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "djangoShell.showEnvironment",
        "title": "Django Shell: Show Process Environment",
        "category": "Django Shell",
        "icon": "$(info)"
      },
      {
        "command": "djangoShell.showDiagnostics",
        "title": "Django Shell: Show Diagnostics Log",
        "category": "Django Shell",
        "icon": "$(output)"
      },
      {
        "command": "djangoShell.refreshInspector",
        "title": "Django Shell: Refresh Runtime Inspector",
        "category": "Django Shell",
        "icon": "$(refresh)"
      },
      {
        "command": "djangoShell.openModelData",
        "title": "Django Shell: Browse Model Data",
        "category": "Django Shell",
        "icon": "$(table)"
      },
      {
        "command": "djangoShell.runModelQuery",
        "title": "Django Shell: Run ORM Query",
        "category": "Django Shell",
        "icon": "$(play)"
      },
      {
        "command": "djangoShell.refreshModelCatalog",
        "title": "Django Shell: Refresh Model Catalog",
        "category": "Django Shell",
        "icon": "$(refresh)"
      }
    ],
    "notebooks": [
      {
        "type": "django-shell-console",
        "displayName": "Django Shell Console (Deprecated)",
        "selector": [
          {
            "filenamePattern": "*.djshell"
          }
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "django-shell-terminal-renderer",
        "displayName": "Django Shell Setup Terminal",
        "entrypoint": "./media/dist/terminalRenderer.js",
        "mimeTypes": [
          "application/vnd.django-shell.terminal+json",
          "application/vnd.django-shell.python-history+json"
        ],
        "requiresMessaging": "always"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "djangoShell",
          "title": "Django Shell",
          "icon": "media/django-shell.svg"
        }
      ]
    },
    "views": {
      "djangoShell": [
        {
          "id": "djangoShell.modelCatalog",
          "name": "Models",
          "type": "webview"
        },
        {
          "id": "djangoShell.runtimeInspector",
          "name": "Runtime"
        },
        {
          "id": "djangoShell.debugAnalysis",
          "name": "Debug Analysis"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "djangoShell.openConsole"
        },
        {
          "command": "djangoShell.debugShell"
        },
        {
          "command": "djangoShell.newOverlayTab"
        },
        {
          "command": "djangoShell.openModelData"
        },
        {
          "command": "djangoShell.runModelQuery"
        },
        {
          "command": "djangoShell.openNotebookConsoleDeprecated"
        },
        {
          "command": "djangoShell.showOverlayEditor"
        },
        {
          "command": "djangoShell.refreshInspector",
          "when": "false"
        },
        {
          "command": "djangoShell.refreshModelCatalog",
          "when": "false"
        },
        {
          "command": "djangoShell.showEnvironment",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "djangoShell.debugShell",
          "group": "navigation@1",
          "when": "resourceFilename == 'debug-cell.py'"
        },
        {
          "command": "djangoShell.debug.continue",
          "group": "navigation@2",
          "when": "djangoShell.externalDebugFrame"
        },
        {
          "command": "djangoShell.debug.stepOver",
          "group": "navigation@3",
          "when": "djangoShell.externalDebugFrame"
        },
        {
          "command": "djangoShell.debug.stepInto",
          "group": "navigation@4",
          "when": "djangoShell.externalDebugFrame"
        },
        {
          "command": "djangoShell.debug.stepOut",
          "group": "navigation@5",
          "when": "djangoShell.externalDebugFrame"
        },
        {
          "command": "djangoShell.debug.stop",
          "group": "navigation@6",
          "when": "djangoShell.externalDebugFrame"
        }
      ],
      "view/title": [
        {
          "command": "djangoShell.openConsole",
          "group": "navigation",
          "when": "view == djangoShell.runtimeInspector"
        },
        {
          "command": "djangoShell.debugShell",
          "group": "navigation@1",
          "when": "view == djangoShell.runtimeInspector"
        },
        {
          "command": "djangoShell.newOverlayTab",
          "group": "navigation@2",
          "when": "view == djangoShell.runtimeInspector"
        },
        {
          "command": "djangoShell.openConsole",
          "group": "navigation",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.debugShell",
          "group": "navigation@1",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.debug.continue",
          "group": "navigation@2",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.debug.pause",
          "group": "navigation@3",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.debug.stepOver",
          "group": "navigation@4",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.debug.stepInto",
          "group": "navigation@5",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.debug.stepOut",
          "group": "navigation@6",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.debug.stop",
          "group": "navigation@7",
          "when": "view == djangoShell.debugAnalysis"
        },
        {
          "command": "djangoShell.refreshInspector",
          "group": "navigation",
          "when": "view == djangoShell.runtimeInspector"
        },
        {
          "command": "djangoShell.showEnvironment",
          "group": "navigation",
          "when": "view == djangoShell.runtimeInspector"
        },
        {
          "command": "djangoShell.openConsole",
          "group": "navigation@1",
          "when": "view == djangoShell.modelCatalog"
        },
        {
          "command": "djangoShell.runModelQuery",
          "group": "navigation@2",
          "when": "view == djangoShell.modelCatalog"
        },
        {
          "command": "djangoShell.refreshModelCatalog",
          "group": "navigation@3",
          "when": "view == djangoShell.modelCatalog"
        }
      ]
    },
    "keybindings": [
      {
        "command": "djangoShell.debug.continue",
        "key": "f5",
        "when": "djangoShell.externalDebugFrame"
      },
      {
        "command": "djangoShell.debug.stepOver",
        "key": "f10",
        "when": "djangoShell.externalDebugFrame"
      },
      {
        "command": "djangoShell.debug.stepInto",
        "key": "f11",
        "when": "djangoShell.externalDebugFrame"
      },
      {
        "command": "djangoShell.debug.stepOut",
        "key": "shift+f11",
        "when": "djangoShell.externalDebugFrame"
      },
      {
        "command": "djangoShell.debug.stop",
        "key": "shift+f5",
        "when": "djangoShell.externalDebugFrame"
      },
      {
        "command": "djangoShell.overlayAcceptInput",
        "key": "enter",
        "mac": "enter",
        "when": "editorTextFocus && editorLangId == 'python' && resourceScheme == 'file' && resourceFilename == 'console-cell.py' && !editorReadonly && !suggestWidgetVisible && !parameterHintsVisible && !inlineSuggestionVisible"
      },
      {
        "command": "djangoShell.overlayInsertNewline",
        "key": "shift+enter",
        "mac": "shift+enter",
        "when": "editorTextFocus && editorLangId == 'python' && resourceScheme == 'file' && resourceFilename == 'console-cell.py' && !editorReadonly"
      },
      {
        "command": "djangoShell.overlayRunCurrentInput",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "djangoShell.overlayVisible && (!editorTextFocus || resourceFilename == 'console-cell.py')"
      },
      {
        "command": "djangoShell.overlaySkipCurrentInput",
        "key": "alt+enter",
        "mac": "alt+enter",
        "when": "djangoShell.overlayVisible && (!editorTextFocus || resourceFilename == 'console-cell.py')"
      },
      {
        "command": "djangoShell.acceptInput",
        "key": "enter",
        "mac": "enter",
        "when": "notebookCellEditorFocused && notebookType == 'django-shell-console' && editorLangId == 'python' && !editorReadonly && !suggestWidgetVisible && !parameterHintsVisible && !inlineSuggestionVisible"
      },
      {
        "command": "type",
        "key": "shift+enter",
        "mac": "shift+enter",
        "args": {
          "text": "\n"
        },
        "when": "notebookCellEditorFocused && notebookType == 'django-shell-console' && editorLangId == 'python' && !editorReadonly"
      }
    ],
    "configuration": {
      "title": "Django Shell",
      "properties": {
        "djangoShell.autoActivateWorkspaceVenv": {
          "type": "boolean",
          "default": true,
          "description": "When true, Django console setup terminals prepend a workspace .venv or venv to PATH and set VIRTUAL_ENV."
        },
        "djangoShell.autoImportModels": {
          "type": "boolean",
          "default": true,
          "description": "When true (default), the Django shell binds your workspace's model classes (and django/apps/settings/models) into the shell namespace at startup, like shell_plus, so names visible in the editor analysis prelude are actually importable. Set to false to keep a plain `manage.py shell` namespace."
        },
        "djangoShell.enableCodeActions": {
          "type": "boolean",
          "default": false,
          "description": "When true, forwards VS Code code actions through the generated Python shadow document. This can be expensive in large Django projects."
        },
        "djangoShell.enableModelPreludeImports": {
          "type": "boolean",
          "default": false,
          "description": "When true, statically scans workspace model files and imports discovered model classes into editor analysis preludes. This is expensive in large Django projects."
        },
        "djangoShell.enableRuntimeCompletion": {
          "type": "boolean",
          "default": false,
          "description": "When true, Django shell cells complete dynamic runtime variables from the attached process. This can be expensive in large Django projects."
        },
        "djangoShell.diagnosticLogging": {
          "type": "boolean",
          "default": true,
          "description": "When true (default), Django Shell logs the shell session, backend requests, and overlay activity to its 'Django Shell' output channel for diagnosis. Set to false to disable."
        },
        "djangoShell.debug.listenHost": {
          "type": "string",
          "default": "127.0.0.1",
          "markdownDescription": "Host passed to `debugpy.listen()` inside the Django shell. Keep `127.0.0.1` for local shells. If `connectHost` is a remote host and this setting is not explicitly configured, Django Shell automatically listens on `0.0.0.0` in the remote process."
        },
        "djangoShell.debug.listenPort": {
          "type": "number",
          "default": 0,
          "markdownDescription": "Port passed to `debugpy.listen()` inside the Django shell. `0` lets debugpy choose a free local port. Use a fixed port such as `5678` when pre-creating an SSH or Kubernetes port-forward."
        },
        "djangoShell.debug.connectHost": {
          "type": "string",
          "default": "",
          "markdownDescription": "Host VS Code connects to for the debugpy attach session. Empty uses the host reported by debugpy or an automatic local port-forward. Set this to the reachable Django server/container/VM host when debugpy is not reachable through local `127.0.0.1`."
        },
        "djangoShell.debug.connectPort": {
          "type": "number",
          "default": 0,
          "markdownDescription": "Port VS Code connects to for the debugpy attach session. `0` uses the port reported by debugpy. For port-forwarding, set this to the local forwarded port."
        },
        "djangoShell.debug.remoteRoot": {
          "type": "string",
          "default": "",
          "markdownDescription": "Remote source root used in Python debug pathMappings. Empty maps the current workspace path to itself. Set this when the remote container path differs from the local workspace path."
        },
        "djangoShell.modelBrowser.lookupExcludeFields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Field-name substrings to hide from the model browser's foreign-key picker search and labels (case-insensitive, e.g. `password`, `token`). By default every text field is shown; add entries here to keep sensitive values out of the picker."
        },
        "djangoShell.modelBrowser.transport": {
          "type": "string",
          "enum": ["auto", "tcp", "pty", "orm"],
          "enumDescriptions": [
            "Auto: prefer the loopback socket, fall back to the terminal — nothing is typed into the shell when the socket is reachable.",
            "Socket: prefer the loopback socket (nothing typed); falls back to the terminal only when the socket is unreachable, e.g. a remote SSH/kubectl shell.",
            "Terminal: force the terminal transport (compact `_djs_rpc(...)` lines, scrubbed from history).",
            "ORM: run model-browser reads as your own literal Django ORM cells in the shell so a live pre_run_cell audit logs Django ORM, not RPC plumbing (execute still uses the socket when reachable). Requires shell_plus/IPython."
          ],
          "default": "orm",
          "markdownDescription": "Default transport for the model data browser. **ORM** (default) runs each model-browser read as your own literal Django ORM cell in the shell so a live `pre_run_cell` audit logs Django ORM, not RPC plumbing (requires shell_plus/IPython); **Terminal** routes reads through the interactive shell as compact `_djs_rpc`/ORM cells scrubbed from history and works everywhere — including remote SSH/kubectl shells where the loopback socket is unreachable; **Auto** prefers the loopback socket and falls back to the terminal — nothing is typed into the shell when the socket is reachable; **Socket** prefers the socket but also falls back to the terminal when it is unreachable (e.g. a remote shell). Switchable per-panel from the `Link:` selector."
        }
      }
    },
    "configurationDefaults": {
      "inlineChat.affordance": "off",
      "inlineChat.notebookAgent": false,
      "notebook.experimental.cellChat": false,
      "notebook.experimental.generate": false,
      "python.analysis.supportAllPythonDocuments": true,
      "[python]": {
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "scripts": {
    "build:custom-console": "esbuild media/customConsoleSource.js --bundle --format=esm --loader:.css=text --outfile=media/dist/customConsole.js",
    "build:model-browser": "esbuild media/modelBrowserSource.js --bundle --format=esm --outfile=media/dist/modelBrowser.js",
    "build:model-catalog": "esbuild media/modelCatalogSource.js --bundle --format=esm --outfile=media/dist/modelCatalog.js",
    "build:renderer": "npm run build:terminal-renderer && npm run build:custom-console && npm run build:model-browser && npm run build:model-catalog",
    "build:terminal-renderer": "esbuild media/terminalRendererSource.js --bundle --format=esm --loader:.css=text --outfile=media/dist/terminalRenderer.js",
    "check:guidelines": "node scripts/check-code-guidelines.mjs",
    "compile": "tsc -p ./ && npm run build:renderer",
    "vscode:prepublish": "npm run compile",
    "test": "npm run compile && node --test test/*.test.mjs",
    "test:e2e": "npm run compile && node test/e2e/run.mjs",
    "check": "npm run check:guidelines && npm run test",
    "package": "npm run check && npx --yes @vscode/vsce package",
    "publish": "npm run check && npm run test:e2e && npx --yes @vscode/vsce publish"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.92.0",
    "@types/vscode-notebook-renderer": "^1.72.4",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.4"
  }
}
